<% layout("layouts/boilerplate") %>
<h1 class="title is-1 has-text-centered mb-6 ">All Campgrounds</h1>

<div class="container-fluid">
  <% for (let campground of campgrounds) { %>
    <ul>
      <div class="card mb-6 has-background-black">
        <div class="columns">
          <div class="column is-one-third">
            <div class="card-image">
              <figure class="image is-5by3">
                <img
                  src="<%=campground.image %>"
                  alt="Placeholder image"
                />
              </figure>
            </div>
          </div>
          <div class="column is-two-thirds">
            <div class="card-content">
              <div class="media">
                <div class="media-content">
                  <p class="title is-2"><%=campground.title %></p>
                  <p class="subtitle is-6">@johnsmith</p>
                </div>
              </div>
              <div class="content">
                <%= campground.description %> 
              </div>
              <div class="content">
                <p class="has-text-grey-dark"><%= campground.location %> </p>
              </div>
              <div class="field is-grouped is-grouped-right">
                <a class="button is-primary is-outlined" href="/campgrounds/<%= campground._id %>">View</a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </ul>
  <% } %>
</div>

